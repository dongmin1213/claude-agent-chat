{
  "name": "claude-agent-chat",
  "version": "0.1.3",
  "description": "Desktop chat interface powered by Claude Agent SDK",
  "author": "Dongmin Kim",
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dongmin1213/claude-agent-chat.git"
  },
  "homepage": "https://github.com/dongmin1213/claude-agent-chat",
  "bugs": {
    "url": "https://github.com/dongmin1213/claude-agent-chat/issues"
  },
  "keywords": [
    "claude",
    "agent",
    "anthropic",
    "electron",
    "nextjs",
    "chat",
    "desktop",
    "ai"
  ],
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "electron:dev": "npx concurrently --kill-others \"next dev --port 13370\" \"npx wait-on http://127.0.0.1:13370 && npx electron . --dev\"",
    "electron:build": "next build && electron-builder --win --config electron-builder.config.js"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.66",
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@tanstack/react-virtual": "^3.13.19",
    "@uiw/react-codemirror": "^4.25.7",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "chokidar": "^5.0.0",
    "next": "^15.2.0",
    "node-pty": "^1.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.3",
    "remark-gfm": "^4.0.0",
    "shiki": "^4.0.0",
    "tree-kill": "^1.2.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "concurrently": "^9.2.1",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.0",
    "tailwindcss": "^4.0.0",
    "typescript": "5.9.3",
    "vitest": "^3.0.0",
    "wait-on": "^9.0.4"
  }
}
